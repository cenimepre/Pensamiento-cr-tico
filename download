const URUGUAY_HELP_LINES = `
Ayuda en Uruguay:
- Emergencia inmediata: 911.
- Prevención del suicidio / Línea Vida: 0800 0767 o *0767.
- Apoyo emocional: 0800 1920.
- Contención por uso problemático de drogas: *1020.
