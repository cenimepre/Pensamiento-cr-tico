const FEELINGS_CHAT_PROMPT = `
Sos la parte conversacional de "Pensamiento crítico".
La persona viene a charlar sobre cómo se siente, no necesariamente a completar un ejercicio.
No sos terapeuta, no diagnosticás y no reemplazás ayuda profesional.

Respondé como una conversación:
- cálida,
- natural,
- breve,
- con una pregunta útil al final cuando tenga sentido.
No uses plantillas largas.
No conviertas todo en ansiedad: puede haber alegría, entusiasmo, calma, tristeza, bronca, orgullo, esperanza o confusión.
Si aparece un pensamiento exagerado, ayudá a mirarlo sin apagar la emoción.

Si hay riesgo de autolesión, suicidio o daño a terceros, priorizá seguridad e incluí:
${URUGUAY_HELP_LINES}
`;

function buildFeelingsMessage(payload) {
  const profile = payload.profileName || "Usuario";
  const message = payload.message || "";
  const emotion = payload.emotion || "";
  const tone = payload.responseTone || "acompañamiento";
  const conversation = payload.conversation || [];
  const recentHistory = payload.recentHistory || [];

  return `
Perfil: ${profile}
Emoción elegida: ${emotion}
Tono elegido: ${tone}

Mensaje actual:
${message}

Conversación reciente:
${JSON.stringify(conversation.slice(-8), null, 2)}

Registros recientes del ejercicio de pensamientos:
${JSON.stringify(recentHistory.slice(0, 5), null, 2)}

Respondé de forma conversacional, sin plantilla rígida.
`;
}

function demoFeelingsResponse(payload) {
  const message = payload.message || "lo que estás sintiendo";
  const emotion = payload.emotion || "lo que sentís";
  const lower = normalize(message);

  if (lower.includes("feliz") || lower.includes("content") || emotion === "felicidad" || emotion === "alegría") {
    return `Me gusta que también traigas algo positivo. Estar feliz no significa que haya que apagar la cabeza: a veces la emoción sube tanto que aparecen pensamientos exagerados tipo “ahora todo va a salir perfecto” o “tengo que hacer todo ya”.

Podés disfrutarlo y a la vez preguntarte: ¿qué parte de esto es entusiasmo real y qué parte es impulso?

¿Qué te gustaría hacer con esa emoción: celebrarla, compartirla o tomar una decisión?`;
  }

  if (lower.includes("no sé") || lower.includes("no se") || emotion === "confusión") {
    return `Tiene sentido que no lo tengas claro todavía. A veces intentar entender todo de golpe solo agrega más ruido.

Podemos empezar más simple: no hace falta resolverlo ahora, solo ubicarlo. ¿Esto se siente más como tristeza, miedo, enojo, cansancio o mezcla de varias cosas?`;
  }

  if (lower.includes("enojo") || emotion === "enojo" || emotion === "frustración") {
    return `El enojo suele aparecer cuando algo se siente injusto, invasivo o demasiado. No hay que negarlo, pero tampoco dejar que decida solo.

Antes de actuar, capaz sirve preguntarte: ¿qué límite o necesidad está intentando defender este enojo?`;
  }

  return `Te leo. Con lo que contás, parece que hay algo que necesita espacio antes de convertirlo en conclusión.

No tengo que darte una solución instantánea. Podemos ir de a poco: ¿querés que te ayude a ordenar lo que sentís, a entender qué pensamiento aparece detrás, o a pensar qué hacer ahora?`;
}


